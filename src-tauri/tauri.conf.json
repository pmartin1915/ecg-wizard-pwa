{
  "productName": "ECG Wizard",
  "version": "0.1.0",
  "identifier": "com.perrymartin.ecgwizard",
  "build": {
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "ECG Wizard - Educational Tool",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "identifier": "com.perrymartin.ecgwizard",
    "publisher": "Perry Martin",
    "category": "Education",
    "shortDescription": "Professional ECG analysis for medical education",
    "longDescription": "A comprehensive ECG analysis tool for learning cardiac rhythm interpretation and arrhythmia detection. Designed for educational purposes - not for clinical decision making.",
    "copyright": "© 2025 Perry Martin. Educational Use Only.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "scope": ["$APPDATA", "$APPDATA/**", "$DESKTOP", "$DESKTOP/**", "$DOCUMENT", "$DOCUMENT/**"]
    },
    "dialog": {
      "open": true,
      "save": true
    },
    "notification": {
      "all": true
    }
  }
}